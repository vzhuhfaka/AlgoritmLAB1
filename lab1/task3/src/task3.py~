from lab1.utils import read_lines, write_in_file


def bin_sum(A, B):
    C = ''
    t = 0
    A = A[::-1]
    B = B[::-1]
    for i in range(0, len(A)):
        a = int(A[i])
        b = int(B[i])
        c = a + b + t
        C += str(c % 2)
        t = c // 2
    if t == 1:
        C += str(t)
    return C[::-1]


if __name__ == '__main__':
    path_input = '../txtf/input.txt'
    path_output = '../txtf/output.txt'

    input_str = read_lines(path_input)[0]
    A = str(input_str[0])
    B = str(input_str[1])

    result = bin_sum(A, B)

    write_in_file(path_output, result)
    print(result)